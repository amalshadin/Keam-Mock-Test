generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  user_id          Int                @id @default(autoincrement())
  name             String
  email            String             @unique
  password_hash    String
  created_at       DateTime           @default(now())
  is_verified      Boolean            @default(false)
  phone            String?
  registrations    ExamRegistration[]
  otpVerifications OTPVerification[]
  attempts         TestAttempt[]
}

model Subject {
  subject_id   Int        @id @default(autoincrement())
  subject_name String     @unique
  questions    Question[]
}

model Question {
  question_id   Int            @id @default(autoincrement())
  subject_id    Int
  question_text String
  answers       Answer[]
  options       Option[]
  subject       Subject        @relation(fields: [subject_id], references: [subject_id])
  tests         TestQuestion[]

  @@index([subject_id])
}

model Option {
  option_id   Int      @id @default(autoincrement())
  question_id Int
  option_text String
  is_correct  Boolean
  answers     Answer[]
  question    Question @relation(fields: [question_id], references: [question_id])

  @@index([question_id])
}

model Test {
  test_id          Int                @id @default(autoincrement())
  title            String
  duration_minutes Int                @default(180)
  created_at       DateTime           @default(now())
  end_time         DateTime?
  price            Float              @default(50.0)
  start_time       DateTime?
  registrations    ExamRegistration[]
  attempts         TestAttempt[]
  questions        TestQuestion[]
}

model TestQuestion {
  test_id     Int
  question_id Int
  question    Question @relation(fields: [question_id], references: [question_id])
  test        Test     @relation(fields: [test_id], references: [test_id])

  @@id([test_id, question_id])
}

model TestAttempt {
  attempt_id      Int              @id @default(autoincrement())
  user_id         Int
  test_id         Int
  started_at      DateTime         @default(now())
  completed_at    DateTime?
  registration_id String           @unique
  status          AttemptStatus    @default(STARTED)
  answers         Answer[]
  registration    ExamRegistration @relation(fields: [registration_id], references: [registration_id])
  test            Test             @relation(fields: [test_id], references: [test_id])
  user            User             @relation(fields: [user_id], references: [user_id])

  @@index([user_id])
  @@index([test_id])
}

model Answer {
  attempt_id           Int
  question_id          Int
  selected_option_id   Int?
  is_marked_for_review Boolean     @default(false)
  attempt              TestAttempt @relation(fields: [attempt_id], references: [attempt_id])
  question             Question    @relation(fields: [question_id], references: [question_id])
  option               Option?     @relation(fields: [selected_option_id], references: [option_id])

  @@id([attempt_id, question_id])
  @@index([attempt_id])
}

model ExamRegistration {
  registration_id String        @id @default(uuid())
  user_id         Int
  test_id         Int
  payment_status  PaymentStatus @default(PENDING)
  payment_id      String?
  amount          Float
  registered_at   DateTime      @default(now())
  test            Test          @relation(fields: [test_id], references: [test_id])
  user            User          @relation(fields: [user_id], references: [user_id])
  attempt         TestAttempt?

  @@unique([user_id, test_id])
}

model OTPVerification {
  id         String   @id @default(uuid())
  user_id    Int
  otp_code   String
  type       String   @default("EMAIL")
  expires_at DateTime
  is_used    Boolean  @default(false)
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [user_id])
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
}

enum AttemptStatus {
  STARTED
  SUBMITTED
}
